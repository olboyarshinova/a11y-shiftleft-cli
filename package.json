{
  "name": "a11y-shiftleft-cli",
  "version": "0.1.0",
  "description": "Framework-agnostic accessibility validation orchestrator for shift-left workflows.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/olboyarshinova/a11y-shiftleft-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/olboyarshinova/a11y-shiftleft-cli.git"
  },
  "bugs": {
    "url": "https://github.com/olboyarshinova/a11y-shiftleft-cli/issues"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "wcag",
    "axe",
    "playwright",
    "eslint",
    "ci",
    "developer-tools"
  ],
  "bin": {
    "a11y-shiftleft": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/",
    "docs/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "demo": "vite --host 127.0.0.1",
    "build:demo": "vite build",
    "test": "node --test",
    "prepack": "npm test",
    "check": "node bin/cli.js check",
    "init": "node bin/cli.js init",
    "ci": "node bin/cli.js ci",
    "post-a11y-comment": "node scripts/post-a11y-comment.js"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@octokit/rest": "^21.1.1",
    "commander": "^12.1.0",
    "csv-stringify": "^6.5.2",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@angular-eslint/eslint-plugin": "^19.0.2",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,html}": [
      "a11y-shiftleft check --static --out reports"
    ]
  }
}
